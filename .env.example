# IMPORTANT — physical phone cannot use localhost.
# Replace 192.168.x.x with your PC IP (same Wi‑Fi). Find it: ipconfig (Windows) or Expo terminal "Network" line.
# Port 8001 may be used by another Django project — Kudya backend (www_kudya_shop) defaults to 8000 locally.
EXPO_PUBLIC_BASE_API=http://192.168.11.195:8000
EXPO_PUBLIC_API_PORT=8000

# Local web/simulator only:
# EXPO_PUBLIC_BASE_API=http://localhost:8000

# Production (requires deployed super-app API routes):
# EXPO_PUBLIC_BASE_API=https://kudya-api.onrender.com
# EXPO_PUBLIC_USE_PRODUCTION_API=true

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_INSTAGRAM_APP_ID=
EXPO_PUBLIC_TIKTOK_CLIENT_KEY=
